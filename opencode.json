{
  "$schema": "https://opencode.ai/config.json",
  "model": "google/gemini-flash-latest",
  "provider": {
    "google": {
      "options": {
        "apiKey": "{env:GEMINI_API_KEY}"
      },
      "models": {
        "gemini-flash-latest": {
          "name": "Gemini Flash (formation)"
        }
      }
    }
  },
  "agent": {
    "relecteur": {
      "description": "Relit les PR et poste un verdict. Aucun acces aux outils.",
      "mode": "subagent",
      "model": "google/gemini-flash-latest",
      "permission": {
        "read": "deny",
        "edit": "deny",
        "bash": "deny",
        "glob": "deny",
        "grep": "deny",
        "task": "deny",
        "webfetch": "deny",
        "websearch": "deny"
      }
    }
  }
}
